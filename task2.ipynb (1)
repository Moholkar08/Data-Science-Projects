   "source": [
    "plt.figure(figsize=(10,6))\n",
    "sns.lineplot(x=\"Year\", y=\"Unemployment_Rate\", hue=\"Country\", data=data, marker=\"o\")\n",
    "plt.title(\"Unemployment Rate Trends by Country\")\n",
    "plt.ylabel(\"Unemployment Rate (%)\")\n",
    "plt.xlabel(\"Year\")\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
