   ],
   "source": [
    "# List of countries and years\n",
    "countries = [\"India\", \"USA\", \"Germany\", \"Brazil\", \"Japan\"]\n",
    "years = np.arange(2010, 2021)  # From 2010 to 2020\n",
    "\n",
    "# Create empty list to store data\n",
    "data_list = []\n",
    "\n",
    "# Generate random unemployment rates for each country and year\n",
    "for country in countries:\n",
    "    for year in years:\n",
    "        rate = np.random.uniform(3, 15)  # unemployment rate between 3% and 15%\n",
    "        data_list.append([country, year, rate])\n",
    "\n",
    "# Convert to DataFrame\n",
    "data = pd.DataFrame(data_list, columns=[\"Country\", \"Year\", \"Unemployment_Rate\"])\n",
    "\n",
    "# Show first few rows\n",
    "print(\"Sample of synthetic dataset:\")\n",
    "print(data.head())"
   ]
  },
